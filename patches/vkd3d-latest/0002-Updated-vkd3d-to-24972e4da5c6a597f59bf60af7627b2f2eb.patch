+static void hlsl_ctx_init_locale(struct hlsl_ctx *ctx)
+{
+#ifdef _WIN32
+    ctx->c_locale = _create_locale(LC_ALL, "C");
+#else
+    ctx->c_locale = newlocale(LC_ALL_MASK, "C", NULL);
+#endif
+}
