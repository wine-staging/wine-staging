+
+            case FIXUP_CMPXCHG:
+                sm6_parser_fixup_cmpxchg(dxil, &state);
+                break;
+        }
+
+        dxil->program->temp_count = max(dxil->program->temp_count, state.temp_idx);
+    }
+
+    dxil->value_count = prev_value_count;
+    dxil->fixup_count = 0;
