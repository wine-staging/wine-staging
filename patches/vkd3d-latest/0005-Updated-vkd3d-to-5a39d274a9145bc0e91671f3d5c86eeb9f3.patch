@@ -1962,6 +1985,8 @@ static void d3dbc_write_instruction(struct d3dbc_compiler *d3dbc, const struct v
 
     for (i = 0; i < ins->src_count; ++i)
     {
+        validate_register_limits(d3dbc, &ins->src[i].reg, &ins->location);
