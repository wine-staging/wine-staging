         X(WAVELANEINDEX)
         X(PARAMETER)
         X(POINT_COORD)
+        X(OUT_POINT_SIZE)
 #undef X
         case VSIR_REGISTER_INVALID:
         case VSIR_REGISTER_TYPE_COUNT:
diff --git a/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c b/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c
index ea788bcfc69..de6bbde1298 100644
