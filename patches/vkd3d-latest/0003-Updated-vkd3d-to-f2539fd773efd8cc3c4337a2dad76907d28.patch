+++ b/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c
@@ -7673,10 +7673,6 @@ static void allocate_semantic_register(struct hlsl_ctx *ctx, struct hlsl_ir_var
         enum vkd3d_decl_usage usage;
         uint32_t usage_idx;
 
-        /* ps_1_* outputs are special and go in temp register 0. */
-        if (version.major == 1 && output && version.type == VKD3D_SHADER_TYPE_PIXEL)
-            return;
-
         builtin = sm1_register_from_semantic_name(&version,
                 var->semantic.name, var->semantic.index, output, NULL, &type, &reg);
         if (!builtin && !sm1_usage_from_semantic_name(var->semantic.name, var->semantic.index, &usage, &usage_idx))
diff --git a/libs/vkd3d/libs/vkd3d-shader/ir.c b/libs/vkd3d/libs/vkd3d-shader/ir.c
index 2c920a3e4ea..2c0a7a263ca 100644
--- a/libs/vkd3d/libs/vkd3d-shader/ir.c
+++ b/libs/vkd3d/libs/vkd3d-shader/ir.c
@@ -144,6 +144,7 @@ const char *vsir_register_type_get_name(enum vsir_register_type type, const char
         [VSIR_REGISTER_OUTPOINTID        ] = "vOutputControlPointID",
         [VSIR_REGISTER_OUTPUT            ] = "o",
         [VSIR_REGISTER_OUTSTENCILREF     ] = "oStencilRef",
+        [VSIR_REGISTER_OUT_POINT_SIZE    ] = "oPts",
         [VSIR_REGISTER_PARAMETER         ] = "parameter",
         [VSIR_REGISTER_PATCHCONST        ] = "vpc",
         [VSIR_REGISTER_POINT_COORD       ] = "vPointCoord",
@@ -3813,9 +3814,8 @@ static enum vkd3d_result vsir_program_normalise_vs3_point_size_output(struct vsi
             /* Remap the PSIZE output register to the point size sysval register. */
             if (reg->type == VSIR_REGISTER_OUTPUT && reg->idx[0].offset == e->register_index)
             {
-                reg->type = VSIR_REGISTER_RASTOUT;
-                reg->idx[0].offset = VSIR_RASTOUT_POINT_SIZE;
-                reg->idx_count = 1;
+                reg->type = VSIR_REGISTER_OUT_POINT_SIZE;
+                reg->idx_count = 0;
             }
         }
     }
@@ -5063,7 +5063,11 @@ static bool vsir_dst_operand_io_normalise(struct vsir_dst_operand *dst,
             }
             /* Leave point size as a system value for the backends to consume. */
             if (reg->idx[0].offset == VSIR_RASTOUT_POINT_SIZE)
+            {
+                reg->type = VSIR_REGISTER_OUT_POINT_SIZE;
+                reg->idx_count = 0;
                 return true;
+            }
             reg_idx = SM1_RASTOUT_REGISTER_OFFSET + reg->idx[0].offset;
             signature = normaliser->output_signature;
             reg->type = VSIR_REGISTER_OUTPUT;
@@ -10139,8 +10143,7 @@ static enum vkd3d_result insert_point_size_before_ret(struct vsir_program *progr
         return VKD3D_ERROR_OUT_OF_MEMORY;
 
     vsir_instruction_init_with_params(program, ins, &loc, VSIR_OP_MOV, 1, 1);
-    vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_RASTOUT, VSIR_DATA_F32, 1);
-    ins->dst[0].reg.idx[0].offset = VSIR_RASTOUT_POINT_SIZE;
+    vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_OUT_POINT_SIZE, VSIR_DATA_F32, 0);
     vsir_src_operand_init_parameter(&ins->src[0], VKD3D_SHADER_PARAMETER_NAME_POINT_SIZE, VSIR_DATA_F32);
     ins = vsir_program_iterator_next(it);
 
@@ -10251,7 +10254,7 @@ static enum vkd3d_result vsir_program_insert_point_size_clamp(struct vsir_progra
             struct vsir_dst_operand *dst = &ins->dst[j];
 
             /* Note we run after I/O normalization. */
-            if (dst->reg.type == VSIR_REGISTER_RASTOUT)
+            if (dst->reg.type == VSIR_REGISTER_OUT_POINT_SIZE)
             {
                 vsir_dst_operand_init_ssa_f32(dst, program->ssa_count);
                 ssa_value = program->ssa_count++;
@@ -10280,8 +10283,7 @@ static enum vkd3d_result vsir_program_insert_point_size_clamp(struct vsir_progra
             }
             else
             {
-                vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_RASTOUT, VSIR_DATA_F32, 1);
-                ins->dst[0].reg.idx[0].offset = VSIR_RASTOUT_POINT_SIZE;
+                vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_OUT_POINT_SIZE, VSIR_DATA_F32, 0);
             }
             ins = vsir_program_iterator_next(&it);
         }
@@ -10291,8 +10293,7 @@ static enum vkd3d_result vsir_program_insert_point_size_clamp(struct vsir_progra
             vsir_instruction_init_with_params(program, ins, loc, VSIR_OP_MIN, 1, 2);
             vsir_src_operand_init_ssa_f32(&ins->src[0], ssa_value);
             vsir_src_operand_init_parameter(&ins->src[1], VKD3D_SHADER_PARAMETER_NAME_POINT_SIZE_MAX, VSIR_DATA_F32);
-            vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_RASTOUT, VSIR_DATA_F32, 1);
-            ins->dst[0].reg.idx[0].offset = VSIR_RASTOUT_POINT_SIZE;
+            vsir_dst_operand_init(&ins->dst[0], VSIR_REGISTER_OUT_POINT_SIZE, VSIR_DATA_F32, 0);
             ins = vsir_program_iterator_next(&it);
         }
     }
@@ -16038,6 +16039,7 @@ static bool is_read_only(const struct vsir_program *program, enum vsir_register_
         case VSIR_REGISTER_NULL:
         case VSIR_REGISTER_OUTPUT:
         case VSIR_REGISTER_OUTSTENCILREF:
+        case VSIR_REGISTER_OUT_POINT_SIZE:
         case VSIR_REGISTER_PREDICATE:
         case VSIR_REGISTER_RASTERIZER:
         case VSIR_REGISTER_RASTOUT:
@@ -16358,6 +16360,7 @@ static bool is_write_only(enum vsir_register_type type)
         case VSIR_REGISTER_DEPTHOUTLE:
         case VSIR_REGISTER_OUTPUT:
         case VSIR_REGISTER_OUTSTENCILREF:
+        case VSIR_REGISTER_OUT_POINT_SIZE:
         case VSIR_REGISTER_RASTOUT:
         case VSIR_REGISTER_TEXCRDOUT:
             return true;
diff --git a/libs/vkd3d/libs/vkd3d-shader/spirv.c b/libs/vkd3d/libs/vkd3d-shader/spirv.c
index 211677e6cb8..8c39418f5f3 100644
--- a/libs/vkd3d/libs/vkd3d-shader/spirv.c
+++ b/libs/vkd3d/libs/vkd3d-shader/spirv.c
@@ -3779,14 +3779,6 @@ static bool spirv_compiler_get_operand_name(char *buffer, unsigned int buffer_si
         case VSIR_REGISTER_CONSTBUFFER:
             snprintf(buffer, buffer_size, "cb%u_%u", operand->idx[0].offset, operand->idx[1].offset);
             break;
-        case VSIR_REGISTER_RASTOUT:
-            if (idx == VSIR_RASTOUT_POINT_SIZE)
-            {
-                snprintf(buffer, buffer_size, "oPts");
-                break;
-            }
-            FIXME("Unhandled rastout register %#x.\n", idx);
-            return false;
         case VSIR_REGISTER_INPUT:
             snprintf(buffer, buffer_size, "v%u", idx);
             break;
@@ -3850,6 +3842,9 @@ static bool spirv_compiler_get_operand_name(char *buffer, unsigned int buffer_si
         case VSIR_REGISTER_POINT_COORD:
             snprintf(buffer, buffer_size, "vPointCoord");
             break;
+        case VSIR_REGISTER_OUT_POINT_SIZE:
+            snprintf(buffer, buffer_size, "oPts");
+            break;
         default:
             FIXME("Unhandled operand type %#x.\n", operand->type);
             snprintf(buffer, buffer_size, "unrecognized_%#x", operand->type);
@@ -5255,10 +5250,6 @@ static const struct vkd3d_spirv_builtin vkd3d_pixel_shader_position_builtin =
 {
     VSIR_DATA_F32, 4, SpvBuiltInFragCoord, frag_coord_fixup,
 };
-static const struct vkd3d_spirv_builtin vkd3d_output_point_size_builtin =
-{
-    VSIR_DATA_F32, 1, SpvBuiltInPointSize,
-};
 static const struct
 {
     enum vsir_register_type reg_type;
@@ -5272,6 +5263,8 @@ vkd3d_register_builtins[] =
     {VSIR_REGISTER_LOCALTHREADINDEX, SpvStorageClassInput,  {VSIR_DATA_I32, 1, SpvBuiltInLocalInvocationIndex}},
     {VSIR_REGISTER_THREADGROUPID,    SpvStorageClassInput,  {VSIR_DATA_I32, 3, SpvBuiltInWorkgroupId}},
 
+    {VSIR_REGISTER_OUT_POINT_SIZE,   SpvStorageClassOutput, {VSIR_DATA_F32, 1, SpvBuiltInPointSize}},
+
     {VSIR_REGISTER_GSINSTID,         SpvStorageClassInput,  {VSIR_DATA_I32, 1, SpvBuiltInInvocationId}},
     {VSIR_REGISTER_OUTPOINTID,       SpvStorageClassInput,  {VSIR_DATA_I32, 1, SpvBuiltInInvocationId}},
 
@@ -5552,12 +5545,7 @@ static const struct vkd3d_symbol *spirv_compiler_emit_io_register(struct spirv_c
     VKD3D_ASSERT(reg->idx_count < 2 || !reg->idx[1].rel_addr);
     VKD3D_ASSERT(reg->idx_count < 3);
 
-    if (reg->type == VSIR_REGISTER_RASTOUT && reg->idx[0].offset == VSIR_RASTOUT_POINT_SIZE)
-    {
-        builtin = &vkd3d_output_point_size_builtin;
-        storage_class = SpvStorageClassOutput;
-    }
-    else if (!(builtin = get_spirv_builtin_for_register(reg->type, &storage_class)))
+    if (!(builtin = get_spirv_builtin_for_register(reg->type, &storage_class)))
     {
         FIXME("Unhandled register %#x.\n", reg->type);
         return NULL;
@@ -7001,10 +6989,11 @@ static void spirv_compiler_emit_point_size(struct spirv_compiler *compiler)
     if (spirv_compiler_is_opengl_target(compiler) || compiler->shader_type == VKD3D_SHADER_TYPE_VERTEX
             || compiler->write_tess_geom_point_size)
     {
-        vkd3d_spirv_build_op_store(&compiler->spirv_builder,
-                spirv_compiler_emit_builtin_variable(compiler,
-                        &vkd3d_output_point_size_builtin, SpvStorageClassOutput, 0),
-                spirv_compiler_get_constant_float(compiler, 1.0f), SpvMemoryAccessMaskNone);
+        struct vsir_dst_operand dst;
+
+        vsir_dst_operand_init(&dst, VSIR_REGISTER_OUT_POINT_SIZE, VSIR_DATA_F32, 0);
+        spirv_compiler_emit_io_register(compiler, &dst);
+        spirv_compiler_emit_store_dst(compiler, &dst, spirv_compiler_get_constant_float(compiler, 1.0f));
     }
 }
 
@@ -10615,8 +10604,7 @@ static void spirv_compiler_emit_io_declarations(struct spirv_compiler *compiler)
 
     if (compiler->program->has_point_size)
     {
-        vsir_dst_operand_init(&dst, VSIR_REGISTER_RASTOUT, VSIR_DATA_F32, 1);
-        dst.reg.idx[0].offset = VSIR_RASTOUT_POINT_SIZE;
+        vsir_dst_operand_init(&dst, VSIR_REGISTER_OUT_POINT_SIZE, VSIR_DATA_F32, 0);
         spirv_compiler_emit_io_register(compiler, &dst);
     }
 
