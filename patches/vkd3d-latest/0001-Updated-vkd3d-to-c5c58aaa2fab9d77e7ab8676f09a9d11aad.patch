+        {
+            vkd3d_shader_parser_error(&dxil->p, VKD3D_SHADER_ERROR_DXIL_OUT_OF_MEMORY,
+                    "Out of memory allocating indirect index for operand copy.");
+            return false;
+        }
+        *operand->idx[i].rel_addr = *template->idx[i].rel_addr;
+    }
+
+    return true;
