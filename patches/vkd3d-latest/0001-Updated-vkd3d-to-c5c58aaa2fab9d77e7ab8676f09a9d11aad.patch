+    vsir_dst_operand_init_ssa_f32v4(&ins->dst[0], normaliser->vpos_ssa);
+    vsir_src_operand_init_io(&ins->src[0], VKD3DSPR_INPUT, vpos, 1);
+    ins->src[0].reg.idx[0].offset = vpos_idx;
+    vsir_program_iterator_next(it);
+
