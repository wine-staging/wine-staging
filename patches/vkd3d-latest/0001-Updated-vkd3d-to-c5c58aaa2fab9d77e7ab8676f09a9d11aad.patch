+                prefix, compiler->colours.literal, -(uint16_t)i, compiler->colours.reset, suffix);
+    else
+        vkd3d_string_buffer_printf(&compiler->buffer, "%s%s%hd%s%s",
+                prefix, compiler->colours.literal, i, compiler->colours.reset, suffix);
