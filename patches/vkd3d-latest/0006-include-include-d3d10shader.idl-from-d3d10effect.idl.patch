From 65d7ec1cb6f3a8c9f844690a74731169c35862e2 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Tue, 23 Jun 2026 09:22:38 +1000
Subject: [PATCH] include: include d3d10shader.idl from d3d10effect.idl
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

In file included from include/d3d10.h:5783,
                 from include/d3d10shader.h:55,
                 from ../wine/libs/vkd3d/libs/vkd3d-common/blob.c:28:
include/d3d10effect.h:339:5: error: unknown type name ‘D3D10_SHADER_VARIABLE_CLASS’; did you mean ‘D3D_SHADER_VARIABLE_CLASS’?
  339 |     D3D10_SHADER_VARIABLE_CLASS Class;
      |     ^~~~~~~~~~~~~~~~~~~~~~~~~~~
      |     D3D_SHADER_VARIABLE_CLASS
include/d3d10effect.h:340:5: error: unknown type name ‘D3D10_SHADER_VARIABLE_TYPE’; did you mean ‘D3D_SHADER_VARIABLE_TYPE’?
  340 |     D3D10_SHADER_VARIABLE_TYPE Type;
      |     ^~~~~~~~~~~~~~~~~~~~~~~~~~
      |     D3D_SHADER_VARIABLE_TYPE
include/d3d10effect.h:3506:9: error: unknown type name ‘D3D10_SIGNATURE_PARAMETER_DESC’
 3506 |         D3D10_SIGNATURE_PARAMETER_DESC *desc);
      |         ^~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
include/d3d10effect.h:3512:9: error: unknown type name ‘D3D10_SIGNATURE_PARAMETER_DESC’
 3512 |         D3D10_SIGNATURE_PARAMETER_DESC *desc);
      |         ^~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
include/d3d10effect.h:3515:1: warning: no semicolon at end of struct or union
 3515 | } ID3D10EffectShaderVariableVtbl;
---
 include/d3d10effect.idl | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/d3d10effect.idl b/include/d3d10effect.idl
index fe526aaf296..688f717447e 100644
--- a/include/d3d10effect.idl
+++ b/include/d3d10effect.idl
@@ -17,7 +17,7 @@
  */
 
 import "d3d10.idl";
-import "d3d10shader.idl";
+#include "d3d10shader.idl"
 
 interface ID3D10EffectConstantBuffer;
 interface ID3D10EffectBlendVariable;
-- 
2.53.0

