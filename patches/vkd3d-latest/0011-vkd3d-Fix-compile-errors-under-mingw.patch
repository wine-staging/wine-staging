From fd3a092f084579e747f599eb9a1827486da6139e Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Fri, 1 May 2026 10:06:09 +1000
Subject: [PATCH] vkd3d: Fix compile errors under mingw

---
 libs/vkd3d/include/private/vkd3d_shader_utils.h | 4 ++++
 libs/vkd3d/libs/vkd3d-shader/preproc.y          | 4 ----
 libs/vkd3d/libs/vkd3d-utils/vkd3d_utils_main.c  | 3 +++
 3 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/libs/vkd3d/include/private/vkd3d_shader_utils.h b/libs/vkd3d/include/private/vkd3d_shader_utils.h
index bef3ee063e2..8ff40f8bf95 100644
--- a/libs/vkd3d/include/private/vkd3d_shader_utils.h
+++ b/libs/vkd3d/include/private/vkd3d_shader_utils.h
@@ -22,6 +22,10 @@
 #include "vkd3d_shader.h"
 #include <sys/stat.h>
 
+#ifndef S_ISREG
+# define S_ISREG(m) (((m) & S_IFMT) == S_IFREG)
+#endif
+
 static inline enum vkd3d_result vkd3d_shader_parse_dxbc_source_type(const struct vkd3d_shader_code *dxbc,
         enum vkd3d_shader_source_type *type, char **messages)
 {
diff --git a/libs/vkd3d/libs/vkd3d-shader/preproc.y b/libs/vkd3d/libs/vkd3d-shader/preproc.y
index ac4d673f8b3..7432bb12d2e 100644
--- a/libs/vkd3d/libs/vkd3d-shader/preproc.y
+++ b/libs/vkd3d/libs/vkd3d-shader/preproc.y
@@ -48,10 +48,6 @@ int preproc_yylex(PREPROC_YYSTYPE *yylval_param, PREPROC_YYLTYPE *yylloc_param,
 
 #define YYLLOC_DEFAULT(cur, rhs, n) (cur) = YYRHSLOC(rhs, !!n)
 
-#ifndef S_ISREG
-# define S_ISREG(m) (((m) & S_IFMT) == S_IFREG)
-#endif
-
 #define preproc_error(ctx, loc, error, ...) \
         preproc_error_(ctx, loc, error, __FUNCTION__, __VA_ARGS__)
 static void VKD3D_PRINTF_FUNC(5, 6) preproc_error_(struct preproc_ctx *ctx, const struct vkd3d_shader_location *loc,
diff --git a/libs/vkd3d/libs/vkd3d-utils/vkd3d_utils_main.c b/libs/vkd3d/libs/vkd3d-utils/vkd3d_utils_main.c
index 383586b1514..ebc8c39e9cf 100644
--- a/libs/vkd3d/libs/vkd3d-utils/vkd3d_utils_main.c
+++ b/libs/vkd3d/libs/vkd3d-utils/vkd3d_utils_main.c
@@ -18,6 +18,9 @@
 
 #include "config.h"
 #include <unistd.h>
+#ifdef _WIN32
+#include <direct.h>   /* getcwd */
+#endif
 #include "vkd3d_utils_private.h"
 #include "vkd3d_shader_utils.h"
 
-- 
2.53.0

