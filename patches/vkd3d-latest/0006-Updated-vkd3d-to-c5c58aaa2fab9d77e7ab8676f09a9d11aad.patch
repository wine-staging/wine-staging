From fc36e45e025c8d5bf3e6a8ac212818ea786bd17d Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Fri, 6 Mar 2026 08:02:57 +1100
Subject: [PATCH] Updated vkd3d to c5c58aaa2fab9d77e7ab8676f09a9d11aad7c0b2.

---
 libs/vkd3d/libs/vkd3d-shader/fx.c           |  7 +--
 libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c |  4 +-
 libs/vkd3d/libs/vkd3d-shader/preproc.h      |  4 +-
 libs/vkd3d/libs/vkd3d-shader/preproc.l      | 63 ++++++++++++++-------
 4 files changed, 49 insertions(+), 29 deletions(-)

diff --git a/libs/vkd3d/libs/vkd3d-shader/fx.c b/libs/vkd3d/libs/vkd3d-shader/fx.c
index d95a61b418a..8eaaec81630 100644
--- a/libs/vkd3d/libs/vkd3d-shader/fx.c
+++ b/libs/vkd3d/libs/vkd3d-shader/fx.c
@@ -17,7 +17,6 @@
  * License along with this library; if not, write to the Free Software
  * Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA 02110-1301, USA
  */
-#include <sys/types.h>
 
 #include "hlsl.h"
 
@@ -5234,10 +5233,10 @@ static void fx_print_fxlc_argument(struct fx_parser *parser, const struct fxlc_a
     bool pending_brace = false;
     unsigned index_level = 0;
 
-    /* register index chain goes outside in, so start at the end. */
-    for (ssize_t i = arg->index_count; i >= 0; --i)
+    for (size_t i = 0; i <= arg->index_count; ++i)
     {
-        const struct fxlc_register *reg = &arg->registers[i];
+        /* register index chain goes outside in, so start at the end. */
+        const struct fxlc_register *reg = &arg->registers[arg->index_count - i];
 
         if (reg->type > FX_FXLC_REG_MAX)
         {
diff --git a/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c b/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c
index 1183a98d932..76c9a36fa48 100644
--- a/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c
+++ b/libs/vkd3d/libs/vkd3d-shader/hlsl_codegen.c
@@ -7117,15 +7117,17 @@ static bool find_constant(struct hlsl_ctx *ctx, const float *f, unsigned int cou
     for (size_t i = 0; i < defs->count; ++i)
     {
         const struct hlsl_constant_register *reg = &defs->regs[i];
+        const float *regf;
 
         if (reg->is_int)
             continue;
+        regf = (float[]){reg->value[0].f, reg->value[1].f, reg->value[2].f, reg->value[3].f};
         for (size_t j = 0; j <= 4 - count; ++j)
         {
             unsigned int writemask = ((1u << count) - 1) << j;
 
             if ((reg->allocated_mask & writemask) == writemask
-                    && !memcmp(f, &reg->value[j].f, count * sizeof(float)))
+                    && !memcmp(f, &regf[j], count * sizeof(float)))
             {
                 ret->type = VKD3DSPR_CONST;
                 ret->id = reg->index;
diff --git a/libs/vkd3d/libs/vkd3d-shader/preproc.h b/libs/vkd3d/libs/vkd3d-shader/preproc.h
index 9217237d8d3..cf7d79938ea 100644
--- a/libs/vkd3d/libs/vkd3d-shader/preproc.h
+++ b/libs/vkd3d/libs/vkd3d-shader/preproc.h
@@ -64,7 +64,7 @@ struct preproc_expansion
     struct preproc_text *arg_values;
     /* Back-pointer to the macro, if this expansion a macro body. This is
      * necessary so that argument tokens can be correctly replaced. */
-    struct preproc_macro *macro;
+    const struct preproc_macro *macro;
 };
 
 struct preproc_macro
@@ -109,7 +109,7 @@ struct preproc_ctx
      */
     struct preproc_func_state
     {
-        struct preproc_macro *macro;
+        const struct preproc_macro *macro;
         size_t arg_count;
         enum
         {
diff --git a/libs/vkd3d/libs/vkd3d-shader/preproc.l b/libs/vkd3d/libs/vkd3d-shader/preproc.l
index bf70099823d..041c3f80ad5 100644
--- a/libs/vkd3d/libs/vkd3d-shader/preproc.l
+++ b/libs/vkd3d/libs/vkd3d-shader/preproc.l
@@ -212,19 +212,23 @@ INT_SUFFIX      [uUlL]{0,2}
 
 %%
 
-static void preproc_func_state_cleanup_arg_values(struct preproc_func_state *f)
+static void preproc_func_state_cleanup(struct preproc_func_state *f)
 {
-    const struct preproc_macro *m;
+    const struct preproc_macro *m = f->macro;
     size_t i;
 
-    if (!(m = f->macro))
-        return;
-
-    for (i = 0; i < m->arg_count; ++i)
+    if (f->arg_values)
     {
-        vkd3d_string_buffer_cleanup(&f->arg_values[i].text);
+        for (i = 0; i < m->arg_count; ++i)
+        {
+            vkd3d_string_buffer_cleanup(&f->arg_values[i].text);
+        }
+        free(f->arg_values);
+        f->arg_values = NULL;
     }
-    free(f->arg_values);
+    f->state = STATE_NONE;
+    f->arg_count = 0;
+    f->macro = NULL;
 }
 
 static void update_location(struct preproc_ctx *ctx)
@@ -266,7 +270,7 @@ static bool preproc_is_writing(struct preproc_ctx *ctx)
  * function-like macro bodies and their arguments. */
 static bool should_concat(struct preproc_ctx *ctx)
 {
-    struct preproc_macro *macro;
+    const struct preproc_macro *macro;
 
     if (!ctx->expansion_count)
         return false;
@@ -369,7 +373,7 @@ static void preproc_text_add(struct preproc_text *text, const char *string)
 }
 
 static bool preproc_push_expansion(struct preproc_ctx *ctx,
-        const struct preproc_text *text, struct preproc_macro *macro, struct preproc_text *arg_values)
+        const struct preproc_text *text, const struct preproc_macro *macro, struct preproc_text *arg_values)
 {
     struct preproc_expansion *exp;
 
@@ -675,8 +679,7 @@ int yylex(YYSTYPE *lval, YYLTYPE *lloc, yyscan_t scanner)
                     const char *name = func_state->macro->name;
 
                     ctx->lookahead_token = token;
-                    func_state->macro = NULL;
-                    func_state->state = STATE_NONE;
+                    preproc_func_state_cleanup(func_state);
 
                     if (ctx->current_directive)
                         return return_token(T_IDENTIFIER, lval, name);
@@ -741,31 +744,34 @@ int yylex(YYSTYPE *lval, YYLTYPE *lloc, yyscan_t scanner)
                     case '}':
                         if (!--func_state->paren_depth)
                         {
+                            const struct preproc_macro *macro = func_state->macro;
+
                             /* Not only can you end a macro with ] or }, if
                              * you do, it's treated as part of the last
                              * argument. */
                             if (token != ')' && current_arg)
                                 preproc_text_add(current_arg, text);
 
-                            if (++func_state->arg_count == func_state->macro->arg_count)
+                            if (++func_state->arg_count == macro->arg_count)
                             {
-                                preproc_push_expansion(ctx, &func_state->macro->body,
-                                        func_state->macro, func_state->arg_values);
+                                preproc_push_expansion(ctx, &macro->body, macro, func_state->arg_values);
+                                func_state->arg_values = NULL;
                             }
                             else
                             {
                                 preproc_warning(ctx, lloc, VKD3D_SHADER_WARNING_PP_ARGUMENT_COUNT_MISMATCH,
                                         "Wrong number of arguments to macro \"%s\": expected %zu, got %zu.",
-                                        func_state->macro->name, func_state->macro->arg_count, func_state->arg_count);
+                                        macro->name, macro->arg_count, func_state->arg_count);
 
                                 if (ctx->current_directive)
-                                    return return_token(T_IDENTIFIER, lval, func_state->macro->name);
+                                {
+                                    preproc_func_state_cleanup(func_state);
+                                    return return_token(T_IDENTIFIER, lval, macro->name);
+                                }
 
-                                vkd3d_string_buffer_printf(&ctx->buffer, "%s ", func_state->macro->name);
-                                preproc_func_state_cleanup_arg_values(func_state);
+                                vkd3d_string_buffer_printf(&ctx->buffer, "%s ", macro->name);
                             }
-                            func_state->macro = NULL;
-                            func_state->state = STATE_NONE;
+                            preproc_func_state_cleanup(func_state);
                         }
                         else
                         {
@@ -888,6 +894,18 @@ int preproc_lexer_parse(const struct vkd3d_shader_compile_info *compile_info,
 
     preproc_yyparse(ctx.scanner, &ctx);
 
+    switch (ctx.directive_func.state)
+    {
+        case STATE_NONE:
+        case STATE_IDENTIFIER:
+            break;
+
+        case STATE_ARGS:
+            preproc_warning(&ctx, &loc, VKD3D_SHADER_WARNING_PP_UNTERMINATED_MACRO,
+                    "Unterminated macro invocation.");
+            break;
+    }
+
     switch (ctx.text_func.state)
     {
         case STATE_NONE:
@@ -903,7 +921,8 @@ int preproc_lexer_parse(const struct vkd3d_shader_compile_info *compile_info,
             break;
     }
 
-    preproc_func_state_cleanup_arg_values(&ctx.text_func);
+    preproc_func_state_cleanup(&ctx.directive_func);
+    preproc_func_state_cleanup(&ctx.text_func);
     while (ctx.file_count)
         preproc_pop_buffer(&ctx);
     yylex_destroy(ctx.scanner);
-- 
2.51.0

