      *  \since 1.14
      */
     VKD3D_SHADER_COMPILE_OPTION_DOUBLE_AS_FLOAT_ALIAS = 0x00000002,
+    /**
+     *  Causes all uniform variables in global scope to be const.
+     *  This includes variables declared without either 'uniform' or 'static',
