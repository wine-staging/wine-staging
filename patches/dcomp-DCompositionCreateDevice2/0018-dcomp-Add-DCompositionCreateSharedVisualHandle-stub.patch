 1041 stub @
 1042 stub @
 
diff --git a/dlls/dcomp/device.c b/dlls/dcomp/device.c
index 342ac1ad5e9..171456e678e 100644
--- a/dlls/dcomp/device.c
+++ b/dlls/dcomp/device.c
@@ -19,6 +19,8 @@
 #include <stdarg.h>
 #include <stdlib.h>
 
+#include "ntstatus.h"
