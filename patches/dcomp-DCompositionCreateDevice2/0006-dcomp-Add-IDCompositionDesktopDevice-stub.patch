         UINT width, UINT height, DXGI_FORMAT pixel_format, DXGI_ALPHA_MODE alpha_mode,
         IDCompositionVirtualSurface **surface)
 {
@@ -365,79 +367,78 @@ static HRESULT STDMETHODCALLTYPE device2_CreateVirtualSurface(IDCompositionDevic
     return E_NOTIMPL;
