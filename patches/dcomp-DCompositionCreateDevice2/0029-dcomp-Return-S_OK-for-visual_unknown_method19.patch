From 5c8e6d21170228dc8c2903ac0a29be8e50c2296e Mon Sep 17 00:00:00 2001
From: Zhiyi Zhang <zzhang@codeweavers.com>
Date: Fri, 13 Mar 2026 10:13:35 +0800
Subject: [PATCH 29/65] dcomp: Return S_OK for visual_unknown_method19().

---
 dlls/dcomp/dcomp_private_iface.idl | 2 +-
 dlls/dcomp/visual.c                | 8 +++++---
 2 files changed, 6 insertions(+), 4 deletions(-)

diff --git a/dlls/dcomp/dcomp_private_iface.idl b/dlls/dcomp/dcomp_private_iface.idl
index c9686503da2..467d32084d8 100644
--- a/dlls/dcomp/dcomp_private_iface.idl
+++ b/dlls/dcomp/dcomp_private_iface.idl
@@ -157,7 +157,7 @@ interface IDCompositionVisualUnknown : IDCompositionVisual2
     HRESULT Unknown16();
     HRESULT Unknown17();
     HRESULT Unknown18();
-    HRESULT Unknown19();
+    HRESULT Unknown19(float parameter1);
     HRESULT Unknown20();
     HRESULT Unknown21();
     HRESULT Unknown22();
diff --git a/dlls/dcomp/visual.c b/dlls/dcomp/visual.c
index 977621da434..4f9e5ea84e2 100644
--- a/dlls/dcomp/visual.c
+++ b/dlls/dcomp/visual.c
@@ -16,6 +16,7 @@
  * Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA 02110-1301, USA
  */
 
+#include <assert.h>
 #include <stdarg.h>
 
 #define COBJMACROS
@@ -392,10 +393,11 @@ static HRESULT WINAPI visual_unknown_method18(IDCompositionVisualUnknown *iface)
     return E_NOTIMPL;
 }
 
-static HRESULT WINAPI visual_unknown_method19(IDCompositionVisualUnknown *iface)
+static HRESULT WINAPI visual_unknown_method19(IDCompositionVisualUnknown *iface, float parameter1)
 {
-    FIXME("iface %p stub!\n", iface);
-    return E_NOTIMPL;
+    FIXME("iface %p parameter1 %f stub!\n", iface, parameter1);
+
+    return S_OK;
 }
 
 static HRESULT WINAPI visual_unknown_method20(IDCompositionVisualUnknown *iface)
