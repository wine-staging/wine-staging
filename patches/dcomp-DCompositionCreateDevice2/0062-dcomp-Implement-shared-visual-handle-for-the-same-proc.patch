@@ -390,6 +391,11 @@ static void test_DCompositionCreateSharedVisualHandle(void)
     {
         ok(!wcscmp(type->TypeName.Buffer, L"Composition"), "Got %s.\n", debugstr_w(type->TypeName.Buffer));
 
