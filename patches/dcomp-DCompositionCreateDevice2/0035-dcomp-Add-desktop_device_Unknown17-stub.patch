From: Zhiyi Zhang <zzhang@codeweavers.com>
Date: Fri, 13 Mar 2026 10:13:35 +0800
Subject: [PATCH 35/65] dcomp: Add desktop_device_Unknown17() stub.

---
 dlls/dcomp/dcomp_private_iface.idl |  2 +-
 dlls/dcomp/device.c                | 11 ++++++++---
 2 files changed, 9 insertions(+), 4 deletions(-)

diff --git a/dlls/dcomp/dcomp_private_iface.idl b/dlls/dcomp/dcomp_private_iface.idl
index 04a3271ab89..47fe8504749 100644
--- a/dlls/dcomp/dcomp_private_iface.idl
+++ b/dlls/dcomp/dcomp_private_iface.idl
@@ -57,7 +57,7 @@ interface IDCompositionDeviceUnknown : IDCompositionDesktopDevicePartner
     HRESULT Unknown14();
     HRESULT Unknown15();
     HRESULT Unknown16();
-    HRESULT Unknown17();
+    HRESULT Unknown17(void **parameter1);
     HRESULT Unknown18();
     HRESULT Unknown19();
     HRESULT Unknown20();
diff --git a/dlls/dcomp/device.c b/dlls/dcomp/device.c
index ef4f2ab8287..6de66da3b67 100644
--- a/dlls/dcomp/device.c
+++ b/dlls/dcomp/device.c
@@ -838,10 +838,15 @@ static HRESULT STDMETHODCALLTYPE desktop_device_Unknown16(IDCompositionDeviceUnk
     return E_NOTIMPL;
 }
 
-static HRESULT STDMETHODCALLTYPE desktop_device_Unknown17(IDCompositionDeviceUnknown *iface)
+static HRESULT STDMETHODCALLTYPE desktop_device_Unknown17(IDCompositionDeviceUnknown *iface, void **parameter1)
 {
-    FIXME("iface %p stub!\n", iface);
-    return E_NOTIMPL;
+    FIXME("iface %p parameter1 %p stub!\n", iface, parameter1);
+
+    if (!parameter1)
+        return E_INVALIDARG;
+
+    *parameter1 = NULL;
+    return S_OK;
 }
 
 static HRESULT STDMETHODCALLTYPE desktop_device_Unknown18(IDCompositionDeviceUnknown *iface)
