From ffe0725b883fe69c2962df3eb6a0eb2fc6665aa1 Mon Sep 17 00:00:00 2001
From: Zhiyi Zhang <zzhang@codeweavers.com>
Date: Fri, 13 Mar 2026 10:13:35 +0800
Subject: [PATCH 40/65] dcomp: Return S_OK for visual_unknown_method14().

---
 dlls/dcomp/dcomp_private_iface.idl | 2 +-
 dlls/dcomp/visual.c                | 7 ++++---
 2 files changed, 5 insertions(+), 4 deletions(-)

diff --git a/dlls/dcomp/dcomp_private_iface.idl b/dlls/dcomp/dcomp_private_iface.idl
index 74a2d5f306d..9be9073f1c7 100644
--- a/dlls/dcomp/dcomp_private_iface.idl
+++ b/dlls/dcomp/dcomp_private_iface.idl
@@ -163,7 +163,7 @@ interface IDCompositionVisualUnknown : IDCompositionVisual2
     HRESULT Unknown11();
     HRESULT Unknown12();
     HRESULT Unknown13();
-    HRESULT Unknown14();
+    HRESULT Unknown14(void *parameter1);
     HRESULT Unknown15();
     HRESULT Unknown16();
     HRESULT Unknown17();
diff --git a/dlls/dcomp/visual.c b/dlls/dcomp/visual.c
index 51238019577..265bb8413b4 100644
--- a/dlls/dcomp/visual.c
+++ b/dlls/dcomp/visual.c
@@ -469,10 +469,11 @@ static HRESULT WINAPI visual_unknown_method13(IDCompositionVisualUnknown *iface)
     return E_NOTIMPL;
 }
 
-static HRESULT WINAPI visual_unknown_method14(IDCompositionVisualUnknown *iface)
+/* parameter1 is from the second parameter of NtCreateCompositionInputSink() */
+static HRESULT WINAPI visual_unknown_method14(IDCompositionVisualUnknown *iface, void *parameter1)
 {
-    FIXME("iface %p stub!\n", iface);
-    return E_NOTIMPL;
+    FIXME("iface %p parameter1 %p stub!\n", iface, parameter1);
+    return S_OK;
 }
 
 static HRESULT WINAPI visual_unknown_method15(IDCompositionVisualUnknown *iface)
